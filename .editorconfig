# EditorConfig configuration for Node.js - https://editorconfig.org
root = true

# Global defaults for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# JavaScript, TypeScript, and JSON specific overrides
[*.{js,jsx,ts,tsx,json}]
indent_size = 2

# Configuration and lock files 
[{package.json,package-lock.json}]
indent_style = space
indent_size = 2

# Markdown file settings
[*.md]
trim_trailing_whitespace = false
